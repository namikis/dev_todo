SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyxxxxxxxxxxxxxxxx
PORT=5177

# GitHub Personal Access Token
# 用途: GitHub Actions の workflow_dispatch トリガー（Claudeリクエストボタン）
# 必要スコープ: repo, workflow
# 取得先: https://github.com/settings/tokens
GITHUB_PAT=ghp_xxxxxxxxxxxx

# Resend メール通知
# 用途: ワークフロー完了時のメール通知（GitHub Actions で使用）
# 取得先: https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx
NOTIFICATION_EMAIL=your-email@example.com
